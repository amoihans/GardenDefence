# scripts/balloon_zombie.gd
# ----------------------------------------------------------------------
# 气球僵尸：飞行单位
#   - 普通豌豆打不到（pea.gd 命中检测会跳过 flying 僵尸）
#   - 解法：火炬 buff 的火球 / 忧郁菇范围攻击 / 磁力菇
#   - 视觉：sprite 已经在 .svg 里表现为"被气球吊着"
# ----------------------------------------------------------------------
extends Zombie

func _ready() -> void:
    flying = true                            # 关键：让豌豆跳过我们
    super._ready()
